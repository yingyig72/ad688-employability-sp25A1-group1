nfig = px.bar(\n    certs, x=\"Certification\", y=[1]*len(certs),\n    color=\"Relevance\",\n    title=\"Recommended Certifications by Category\",\n    hover_data=[\"Difficulty\", \"Approx. Cost\", \"Time to Complete\"]\n)\nfig.update_layout(yaxis_visible=False, showlegend=True, height=350)\nfig.update_traces(hovertemplate=\"<b>%{x}</b><br>Difficulty: %{customdata[0]}<br>Cost: %{customdata[1]}<br>Duration: %{customdata[2]}\")\nfig.show()\n\ncerts\n```\n\n::: {#certifications-1 .cell-output .cell-output-display}\n```{=html}\n<div>            <script src=\"https://cdnjs.cloudflare.com/ajax/libs/mathjax/2.7.5/MathJax.js?config=TeX-AMS-MML_SVG\"></script><script>if (window.MathJax && window.MathJax.Hub && window.MathJax.Hub.Config) {window.MathJax.Hub.Config({SVG: {font: \"STIX-Web\"}});}</script>                <script>window.PlotlyConfig = {MathJaxConfig: 'local'};</script>\n        <script charset=\"utf-8\" src=\"https://cdn.plot.ly/plotly-3.5.0.min.js\" integrity=\"sha256-fHbNLP+GlIXN+efbQec78UkemUz3NJp7UmfGxC1tNxs=\" crossorigin=\"anonymous\"></script>                <div id=\"1f4e348d-1dec-4475-9538-ab1e8f4374a5\" class=\"plotly-graph-div\" style=\"height:350px; width:100%;\"></div>            <script>                window.PLOTLYENV=window.PLOTLYENV || {};                                if (document.getElementById(\"1f4e348d-1dec-4475-9538-ab1e8f4374a5\")) {                    Plotly.newPlot(                        \"1f4e348d-1dec-4475-9538-ab1e8f4374a5\",                        [{\"customdata\":[[\"Beginner\",\"$100\",\"2-4 weeks\"],[\"Intermediate\",\"$150\",\"4-8 weeks\"],[\"Beginner\",\"Free\",\"1-2 weeks\"]],\"hovertemplate\":\"\\u003cb\\u003e%{x}\\u003c\\u002fb\\u003e\\u003cbr\\u003eDifficulty: %{customdata[0]}\\u003cbr\\u003eCost: %{customdata[1]}\\u003cbr\\u003eDuration: %{customdata[2]}\",\"legendgroup\":\"Cloud\",\"marker\":{\"color\":\"#3498db\",\"pattern\":{\"shape\":\"\"}},\"name\":\"Cloud\",\"orientation\":\"v\",\"showlegend\":true,\"textposition\":